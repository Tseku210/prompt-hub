---
import Layout from "../layouts/Layout.astro";
import { PromptHub } from "../components/PromptHub";
import { getCollection } from "astro:content";

const allPrompts = await getCollection("prompts");
const prompts = allPrompts.map((p) => ({
  id: p.id,
  ...p.data,
  body: p.body ?? "",
}));
---

<Layout>
  <div class="min-h-[calc(100vh-68px)]">
    
  <PromptHub client:only="react" prompts={prompts}>
    <div class="max-w-6xl mx-auto px-4 sm:px-6 py-8 space-y-6 animate-pulse">
      <!-- Title -->
      <div class="flex flex-col items-center gap-5 mb-10">
        <div class="size-50 rounded-full bg-muted"></div>
        <div class="h-12 w-48 bg-muted"></div>
      </div>
      <!-- Search bar -->
      <div class="max-w-lg mx-auto">
        <div class="h-10 w-full  bg-muted"></div>
      </div>
      <!-- Filter bar -->
      <div class="flex justify-center gap-2">
        <div class="h-9 w-16 bg-muted"></div>
        <div class="h-9 w-24 bg-muted"></div>
        <div class="h-9 w-20 bg-muted"></div>
        <div class="h-9 w-24 bg-muted"></div>
      </div>
      <!-- Prompt grid -->
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 pt-4">
        <div class="h-44 bg-muted"></div>
        <div class="h-44 bg-muted"></div>
        <div class="h-44 bg-muted"></div>
        <div class="h-44 bg-muted hidden sm:block"></div>
        <div class="h-44 bg-muted hidden sm:block"></div>
        <div class="h-44 bg-muted hidden lg:block"></div>
      </div>
    </div>
    </PromptHub>
  </div>
</Layout>
