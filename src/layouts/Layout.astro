---
import "../styles/global.css";
import { Font } from "astro:assets";
---


<!doctype html>
<html lang="en" class="dark">
	<head>
    <Font cssVariable="--font-jetbrains" preload />
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32x32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16x16.png" />
    <link rel="manifest" href="/site.webmanifest" />
		<meta name="generator" content={Astro.generator} />
		<meta name="description" content="A curated library of reusable LLM prompt templates for my personal use." />


		<title>Prompt Hub | Tsekushi</title>
	</head>
	<body>
		<slot />
		<footer class="py-6 text-center text-sm text-muted-foreground">
			built by <a href="https://tseku.dev" target="_blank" rel="noopener noreferrer" class="underline underline-offset-4 hover:text-foreground transition-colors">Tseku</a>
		</footer>
	</body>
</html>

<style>
	html,
	body {
		margin: 0;
		width: 100%;
		min-height: 100%;
	}
</style>
